<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded-rectangle background for the W'bal fields. Solid white so it can be tinted to the
     status color at runtime via setBackgroundTintList; the corner radius matches Karoo's
     rounded field edge so the color doesn't bleed past it. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#FFFFFFFF" />

    <corners android:radius="8dp" />

</shape>
